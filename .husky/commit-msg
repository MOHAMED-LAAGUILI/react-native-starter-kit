commit_msg=$(cat "$1")

pattern="^(feat|fix|update|docs|style|refactor|perf|test|build|ci|chore|revert|improve)(\([a-z0-9._-]+\))?: .{1,}$"

if echo "$commit_msg" | grep -qE "$pattern"; then
  exit 0
fi

echo ""
echo "❌ Invalid commit message format!"
echo ""
echo "Expected: type(scope?): description"
echo ""
echo "Allowed types:"
echo "  feat      New feature"
echo "  fix       Bug fix" 
echo "  update    Update existing functionality"
echo "  docs      Documentation only"
echo "  style     Code style (formatting, semicolons, etc)"
echo "  refactor  Code refactoring"
echo "  perf      Performance improvement"
echo "  test      Adding or fixing tests"
echo "  build     Build system or dependencies"
echo "  ci        CI configuration"
echo "  chore     Maintenance tasks"
echo "  revert    Revert a previous commit"
echo "  improve   Improvement without new feature or fix"
echo ""
echo "Examples:"
echo "  fix: fixed a minor bug in btn"
echo "  update: updated login screen layout"
echo "  feat(auth): add biometric login"
echo ""
exit 1
