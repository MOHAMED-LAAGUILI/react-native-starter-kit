{
  "name": "react-native-expo-starter-kit",
  "main": "expo-router/entry",
  "version": "2.3.0",
  "packageManager": "bun",
  "keywords": [
    "react-native",
    "expo",
    "ui",
    "cli",
    "starter-kit",
    "template",
    "typescript"
  ],
  "author": "MOHAMED-LAAGUILI <mohamed.dev.2001@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MOHAMED-LAAGUILI/react-native-expo-starter-kit.git"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "expo start -c",
    "android": "expo start -c -a",
    "ios": "expo start -c -i",
    "web": "expo start -c -w",
    "mac:ios": "npx pod-install",
    "clean:cache":"bun pm cache rm",
    "clean:app": "bun run clean:cache && rm -rf .expo node_modules android ios build dist bun.lock",
    "deps:fix": "npx expo install --fix",
    "lint:fix": "eslint . --fix && npx eslint src/ --fix && npx eslint app/ --fix",
    "type:check": "tsc --noemit",
    "doctor": "npx expo-doctor@latest --verbose && npx react-doctor@latest --verbose",
    "checks": "bun run deps:fix && bun run lint:fix && bun run type:check && bun run doctor",
    "expo:config": "npx expo config --type public",
    "generate:apk": "\"C:/Program Files/Git/bin/bash.exe\" script/generate-apk-and-install.sh",
    "prebuild": "expo prebuild --platform all",
    "prebuild:prev": "cross-env EXPO_PUBLIC_APP_ENV=preview STRICT_ENV_VALIDATION=1 expo prebuild --platform all",
    "prebuild:dev": "cross-env EXPO_PUBLIC_APP_ENV=development STRICT_ENV_VALIDATION=1 expo prebuild --platform all",
    "prebuild:prod": "cross-env EXPO_PUBLIC_APP_ENV=production STRICT_ENV_VALIDATION=1 expo prebuild --platform all",
    "prebuild:generate": "bun run prebuild && bun run generate:apk",
    "android:dev": "cross-env EXPO_PUBLIC_APP_ENV=development bun run android",
    "ios:dev": "cross-env EXPO_PUBLIC_APP_ENV=development bun run ios",
    "android:prev": "cross-env EXPO_PUBLIC_APP_ENV=preview bun run android",
    "ios:prev": "cross-env EXPO_PUBLIC_APP_ENV=preview bun run ios",
    "android:prod": "cross-env EXPO_PUBLIC_APP_ENV=production bun run android",
    "ios:prod": "cross-env EXPO_PUBLIC_APP_ENV=production bun run ios",
    "eas:in": "eas login",
    "eas:id": "eas whoami",
    "eas:out": "eas logout",
    "build:dev:ios": "eas build --profile development --platform ios --clear-cache",
    "build:dev:android": "eas build --profile development --platform android --clear-cache",
    "build:prev:ios": "eas build --profile preview --platform ios --clear-cache",
    "build:prev:android": "eas build --profile preview --platform android --clear-cache",
    "build:prod:ios": "eas build --profile production --platform ios --clear-cache",
    "build:prod:android": "eas build --profile production --platform android --clear-cache",
    "flow:build-android:main": "npx eas-cli@latest workflow:run create-build-android-main.yml",
    "flow:build-ios:main": "npx eas-cli@latest workflow:run create-build-ios-main.yml",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "eas:update:config": "eas update:configure",
    "eas:update:prod": "eas update --channel production --message 'new update message' --environment production",
    "export:web": "npx expo export --platform web",
    "deploy:web": "eas deploy --prod"
  },
  "dependencies": {
    "@backpackapp-io/react-native-toast": "^0.15.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@gorhom/bottom-sheet": "^5",
    "@lottiefiles/dotlottie-react": "^0.19.9",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@react-native-menu/menu": "^2.0.0",
    "@react-navigation/drawer": "^7",
    "@react-navigation/native-stack": "^7",
    "@rn-primitives/dropdown-menu": "^1.5.2",
    "@rn-primitives/portal": "~1.4.0",
    "@rn-primitives/progress": "^1.5.2",
    "@rn-primitives/radio-group": "^1.5.2",
    "@rn-primitives/switch": "^1.5.2",
    "@rn-primitives/toggle": "^1.5.2",
    "@tanstack/react-form": "^1",
    "@tanstack/react-query": "^5",
    "@tanstack/react-query-devtools": "^5",
    "app-icon-badge": "^0.1.2",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "expo": "~57.0.7",
    "expo-build-properties": "~57.0.6",
    "expo-constants": "~57.0.6",
    "expo-dev-client": "~57.0.7",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "^57.0.0",
    "expo-linear-gradient": "^57.0.0",
    "expo-linking": "~57.0.3",
    "expo-localization": "^57.0.0",
    "expo-navigation-bar": "^57.0.1",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "^57.0.0",
    "expo-updates": "~57.0.8",
    "expo-video": "^57.0.0",
    "i18next": "^26.3.4",
    "lottie-react-native": "^7.3.8",
    "lucide-react-native": "^1.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-calendars": "^1.1314.0",
    "react-native-dotenv": "^3.4.11",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.5.0",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-restart-newarch": "^1.0.87",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-toast-message": "^2.4.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.10.0",
    "react-navigation-header-buttons": "^13.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "uniwind": "^1.10.0",
    "zod": "^3",
    "zustand": "^5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@babel/core": "^7.26.0",
    "@eslint-react/eslint-plugin": "^5.13.2",
    "@expo/config": "^57.0.2",
    "@react-native-community/cli": "^20.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-doctor": "^0.7.8",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "enabled": true,
        "exclude": []
      }
    },
    "install": {
      "exclude": []
    }
  },
  "trustedDependencies": [
    "esbuild",
    "unrs-resolver"
  ]
}
