{
  "name": "react-native-starter-kit",
  "main": "expo-router/entry",
  "version": "2.1.0",
  "packageManager": "bun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MOHAMED-LAAGUILI/react-native-starter-kit.git"
  },
  "scripts": {
    "dev": "expo start -c",
    "android": "expo start -c -a",
    "ios": "expo start -c -i",
    "web": "expo start -c -w",
    "clean": "bun pm cache rm && rm -rf .expo node_modules android ios build dist bun.lock",
    "eas:login": "eas login",
    "eas:id":"eas whoami",
    "eas:logout": "eas logout",
    "deps:fix": "npx expo install --fix",
    "lint:fix": "eslint . --fix && npx eslint src/ --fix && npx eslint app/ --fix",
    "type:check": "tsc --noemit",
    "doctor": "npx expo-doctor --verbose",
    "expo:config": "npx expo config --type public",
    "export:web": "npx expo export --platform web",
    "generate:apk": "\"C:/Program Files/Git/bin/bash.exe\" script/generate-apk-and-install.sh",
    "prebuild": "expo prebuild --platform all",
    "prebuild:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview STRICT_ENV_VALIDATION=1 expo prebuild --platform all",
    "prebuild:development": "cross-env EXPO_PUBLIC_APP_ENV=development STRICT_ENV_VALIDATION=1 expo prebuild --platform all",
    "prebuild:production": "cross-env EXPO_PUBLIC_APP_ENV=production STRICT_ENV_VALIDATION=1 expo prebuild --platform all",
    "prebuild:generate":"bun run prebuild && bun run generate:apk",
    "android:development": "cross-env EXPO_PUBLIC_APP_ENV=development bun run android",
    "ios:development": "cross-env EXPO_PUBLIC_APP_ENV=development bun run ios",
    "android:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview bun run android",
    "ios:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview bun run ios",
    "android:production": "cross-env EXPO_PUBLIC_APP_ENV=production bun run android",
    "ios:production": "cross-env EXPO_PUBLIC_APP_ENV=production bun run ios",
    "workflow:build-ios:preview": "npx eas-cli@latest workflow:run create-build-ios-preview.yml",
    "workflow:build-android:preview": "npx eas-cli@latest workflow:run create-build-android-preview.yml",
    "workflow:build-ios:main": "npx eas-cli@latest workflow:run create-build-ios-main.yml",
    "workflow:build-android:main": "npx eas-cli@latest workflow:run create-build-android-main.yml",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "deploy": "eas deploy"
  },
  "dependencies": {
    "@backpackapp-io/react-native-toast": "^0.15.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5",
    "@lottiefiles/dotlottie-react": "^0.19.8",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@react-navigation/drawer": "^7",
    "@react-navigation/native-stack": "^7",
    "@rn-primitives/accordion": "^1.5.2",
    "@rn-primitives/alert-dialog": "^1.5.2",
    "@rn-primitives/aspect-ratio": "^1.5.2",
    "@rn-primitives/avatar": "^1.5.2",
    "@rn-primitives/checkbox": "^1.5.2",
    "@rn-primitives/collapsible": "^1.5.2",
    "@rn-primitives/context-menu": "^1.5.2",
    "@rn-primitives/dialog": "^1.5.2",
    "@rn-primitives/dropdown-menu": "^1.5.2",
    "@rn-primitives/hover-card": "^1.5.2",
    "@rn-primitives/label": "^1.5.2",
    "@rn-primitives/menubar": "^1.5.2",
    "@rn-primitives/popover": "^1.5.2",
    "@rn-primitives/portal": "~1.4.0",
    "@rn-primitives/progress": "^1.5.2",
    "@rn-primitives/radio-group": "^1.5.2",
    "@rn-primitives/select": "^1.5.2",
    "@rn-primitives/separator": "^1.5.2",
    "@rn-primitives/slot": "^1.5.2",
    "@rn-primitives/switch": "^1.5.2",
    "@rn-primitives/tabs": "^1.5.2",
    "@rn-primitives/toggle": "^1.5.2",
    "@rn-primitives/toggle-group": "^1.5.2",
    "@rn-primitives/tooltip": "^1.5.2",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-form": "^1",
    "@tanstack/react-query": "^5",
    "@tanstack/react-query-devtools": "^5",
    "app-icon-badge": "^0.1.2",
    "axios": "^1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^57.0.0",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "^57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "^57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "^57.0.0",
    "expo-updates": "~57.0.6",
    "i18next": "^26.3.4",
    "lodash.memoize": "^4.1.2",
    "lottie-react-native": "^7.3.8",
    "lucide-react-native": "^1.21.0",
    "moti": "^0.30.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-dotenv": "^3.4.11",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-reanimated": "4.5.0",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-restart-newarch": "^1.0.87",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-toast-message": "^2.4.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.10.1",
    "react-navigation-header-buttons": "^13.0.0",
    "react-query-kit": "^3.3.4",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "uniwind": "^1.10.0",
    "zod": "^3",
    "zustand": "^5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@babel/core": "^7.26.0",
    "@eslint-react/eslint-plugin": "^5.13.2",
    "@expo/config": "^57.0.2",
    "@react-native-community/cli": "^20.2.0",
    "@types/node": "^26.1.0",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": ["expo-dynamic-app-icon"]
      }
    },
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    }
  },
  "trustedDependencies": [
    "esbuild",
    "unrs-resolver"
  ]
}
